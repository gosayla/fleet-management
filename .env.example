# ── Production Environment Variables ─────────────────────────────────────────
# Copy this file to .env on the server and fill in your values
# NEVER commit .env to git

# JWT
JWT_SECRET=replace_with_a_long_random_secret_min_64_chars

# Database (used by docker-compose)
POSTGRES_DB=fleet_db
POSTGRES_USER=fleet_user
POSTGRES_PASSWORD=replace_with_strong_password

# Tamm Integration
TAMM_MOCK=false
TAMM_BASE_URL=https://tamm.api.elm.sa
TAMM_IDP_URL=https://idp.elm.sa
TAMM_IDP_REALM=Tamm
TAMM_MOI_NUMBER=your_moi_number
TAMM_CLIENT_ID=your_client_id
TAMM_CLIENT_SECRET=your_client_secret

# Naql Integration
NAQL_MOCK=false

# Web — public URL the frontend will use to reach the API
NEXT_PUBLIC_API_URL=https://fleet-api.yourdomain.com/api/v1
NEXT_PUBLIC_SOCKET_URL=https://fleet-api.yourdomain.com
