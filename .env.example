# ── Production Environment Variables ─────────────────────────────────────────
# Copy this file to .env on the server and fill in your values.
# NEVER commit .env to git.

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=replace_with_a_long_random_secret_min_64_chars

# ── App URL (used for CORS) ───────────────────────────────────────────────────
APP_URL=https://your-domain.com

# ── Web port exposed on the host (reverse proxy should point here) ────────────
WEB_PORT=3002

# ── WebSocket public URL (same as APP_URL for production) ────────────────────
NEXT_PUBLIC_SOCKET_URL=https://your-domain.com

# ── Tamm Integration ──────────────────────────────────────────────────────────
# Set TAMM_MOCK=true to disable real API calls during development / staging
TAMM_MOCK=true
TAMM_BASE_URL=https://tamm.api.elm.sa
TAMM_IDP_URL=https://idp.elm.sa/auth
TAMM_IDP_REALM=Tamm
TAMM_MOI_NUMBER=your_moi_number
TAMM_CLIENT_ID=your_client_id
TAMM_CLIENT_SECRET=your_client_secret

# ── Naql Integration ──────────────────────────────────────────────────────────
# Set NAQL_MOCK=true until real credentials are available
NAQL_MOCK=true

# ── Pilot GPS Integration ─────────────────────────────────────────────────────
PILOT_GPS_TOKEN=your_pilot_gps_monitor_token
