{
  "info": {
    "_postman_id": "7f6a9051-6be6-4ac8-b2c2-66a791d4f5f1",
    "name": "Tamm Direct API Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "https://tamm.api.elm.sa" },
    { "key": "idp_url", "value": "https://idp.elm.sa" },
    { "key": "realm", "value": "Tamm" },
    { "key": "client_id", "value": "db7adee4" },
    { "key": "client_secret", "value": "b84afcc8825a119662db1ef6ac4974a5" },
    { "key": "moi_number", "value": "7029295180" },
    { "key": "access_token", "value": "" },
    { "key": "conversation_id", "value": "" }
  ],
  "item": [
    {
      "name": "1. Get OAuth Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.access_token) {",
              "  pm.collectionVariables.set('access_token', json.access_token);",
              "}",
              "pm.test('Token returned', function () {",
              "  pm.expect(json.access_token).to.be.a('string').and.not.empty;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            { "key": "grant_type", "value": "client_credentials", "type": "text" },
            { "key": "client_id", "value": "{{client_id}}", "type": "text" },
            { "key": "client_secret", "value": "{{client_secret}}", "type": "text" }
          ]
        },
        "url": {
          "raw": "{{idp_url}}/auth/realms/{{realm}}/protocol/openid-connect/token",
          "host": ["{{idp_url}}"],
          "path": ["auth", "realms", "{{realm}}", "protocol", "openid-connect", "token"]
        }
      }
    },
    {
      "name": "2. Traffic Violations - Unpaid",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{access_token}}" },
          { "key": "X-Integrator-User-Id", "value": "{{moi_number}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"searchType\": 0,\n  \"idNumber\": \"{{moi_number}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/inquiry/traffic-violations?page=0&size=10",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "inquiry", "traffic-violations"],
          "query": [
            { "key": "page", "value": "0" },
            { "key": "size", "value": "10" }
          ]
        }
      }
    },
    {
      "name": "3. Traffic Violations - Paid",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{access_token}}" },
          { "key": "X-Integrator-User-Id", "value": "{{moi_number}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"searchType\": 0,\n  \"idNumber\": \"{{moi_number}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/inquiry/traffic-violations/paid?page=0&size=10",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "inquiry", "traffic-violations", "paid"],
          "query": [
            { "key": "page", "value": "0" },
            { "key": "size", "value": "10" }
          ]
        }
      }
    },
    {
      "name": "4. MVPI by Sequence Number",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{access_token}}" },
          { "key": "X-Integrator-User-Id", "value": "{{moi_number}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"searchType\": 1,\n  \"sequenceNumber\": \"997630501\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/inquiry/mvpi/latest-inspection",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "inquiry", "mvpi", "latest-inspection"]
        }
      }
    },
    {
      "name": "5. Vehicle Insurance by Sequence Number",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{access_token}}" },
          { "key": "X-Integrator-User-Id", "value": "{{moi_number}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"searchType\": 1,\n  \"sequenceNumber\": \"997630501\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/inquiry/vehicle-insurance",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "inquiry", "vehicle-insurance"]
        }
      }
    },
    {
      "name": "6. Actual Driver - Verify Vehicle",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "let json = {};",
              "try { json = pm.response.json(); } catch (e) {}",
              "const conversationId = json.id || json.conversationId;",
              "if (conversationId) {",
              "  pm.collectionVariables.set('conversation_id', conversationId);",
              "}",
              "pm.test('Conversation id captured when present', function () {",
              "  pm.expect(true).to.eql(true);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{access_token}}" },
          { "key": "X-Integrator-User-Id", "value": "{{moi_number}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"plateDto\": {\n    \"text1\": \"د\",\n    \"text2\": \"ع\",\n    \"text3\": \"د\",\n    \"number\": 1946,\n    \"type\": { \"code\": 1 }\n  }\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/actual-driver/addition/verifyVehicle",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "actual-driver", "addition", "verifyVehicle"]
        }
      }
    },
    {
      "name": "7. Actual Driver - Verify Addition",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{access_token}}" },
          { "key": "X-Integrator-User-Id", "value": "{{moi_number}}" },
          { "key": "X-Conversation-Id", "value": "{{conversation_id}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"idNumber\": \"{{moi_number}}\",\n  \"type\": 2,\n  \"crossValidationBy\": 1,\n  \"residentIqamaId\": \"2108824836\",\n  \"mobileNumber\": \"558526036\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/actual-driver/addition/verify",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "actual-driver", "addition", "verify"]
        }
      }
    },
    {
      "name": "8. Actual Driver - Final Submit",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{access_token}}" },
          { "key": "X-Integrator-User-Id", "value": "{{moi_number}}" },
          { "key": "X-Conversation-Id", "value": "{{conversation_id}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"otp\": null\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/actual-driver/addition/",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "actual-driver", "addition", ""]
        }
      }
    }
  ]
}
