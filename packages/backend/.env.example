# Backend Environment Variables
# Copy this file to .env and fill in your values

# Application
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3000

# Database
DATABASE_URL="postgresql://fleet_user:fleet_pass@localhost:5432/fleet_db?schema=public"

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_at_least_64_chars
JWT_EXPIRES_IN=7d

# Tamm API (tamm.sa — ELM platform for Saudi vehicle services)
TAMM_BASE_URL=https://tamm.sa/api
TAMM_MOI_NUMBER=your_moi_number
TAMM_CLIENT_ID=your_client_id
TAMM_CLIENT_SECRET=your_client_secret
# Legacy fallback (optional)
TAMM_USERNAME=
TAMM_PASSWORD=
TAMM_MOCK=true  # set to false once real credentials are available

# Naql API (naql.com.sa — Saudi transport & logistics platform)
NAQL_BASE_URL=https://api.naql.com.sa
NAQL_API_KEY=your_naql_api_key
NAQL_COMPANY_CODE=your_company_code
NAQL_MOCK=true  # set to false once real credentials are available

# Pilot GPS integration
PILOT_GPS_TOKEN=your_pilot_gps_monitor_token

# SmartTracker GPS integration (gps.smarttrackerpro.net)
SMARTTRACKER_USERNAME=your_smarttracker_username
SMARTTRACKER_PASSWORD=your_smarttracker_password

# TMT GPS integration (track.tmtgps.io) — auto-login URL provided by the platform
TMTGPS_AUTH_URL=https://track.tmtgps.io/index.php?au=your_au_token

# Firebase (FCM push notifications)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# File Storage (local for dev; switch to S3/R2 in production)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
